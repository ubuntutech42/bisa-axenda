/**
 * @file Firebase Security Rules for Axénda application.
 *
 * @description
 * This ruleset enforces a user-ownership model for most data, with public read access to cultural events.
 *
 * Data Structure:
 * - /users/{userId}: Stores user profiles, accessible only by the owning user.
 * - /kanbanBoards/{boardId}: Stores Kanban boards, accessible only by the owning user.
 * - /kanbanBoards/{boardId}/lists/{listId}: Stores Kanban lists, accessible only by the owning user (via board ownership).
 * - /kanbanBoards/{boardId}/tasks/{taskId}: Stores tasks, accessible only by the owning user (via board ownership).
 * - /users/{userId}/categories/{categoryId}: Stores user-specific categories, accessible only by the owning user.
 * - /users/{userId}/pomodoroSessions/{pomodoroSessionId}: Stores Pomodoro sessions, accessible only by the owning user.
 * - /users/{userId}/calendarEvents/{calendarEventId}: Stores calendar events, accessible only by the owning user.
 * - /culturalEvents/{culturalEventId}: Stores global cultural events, publicly readable.
 *
 * Key Security Decisions:
 * - User listing is disallowed.
 * - Cultural events are publicly readable but not writable by clients.
 * - Data validation is relaxed in prototyping mode to allow for schema iteration. Only authorization-critical fields are validated.
 *
 * Denormalization for Authorization:
 * - Kanban boards, lists, and tasks all store the `userId` of the board owner. This allows for efficient authorization checks without needing to perform additional `get()` operations.
 *
 * Structural Segregation:
 * - Private user data (categories, Pomodoro sessions, calendar events) is stored under the `/users/{userId}` path, while public cultural events are stored in a top-level collection.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Allows users to read and write their own profile data.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their profile.
     * @allow (get) User with ID 'user123' can read their profile.
     * @allow (update) User with ID 'user123' can update their profile.
     * @allow (delete) User with ID 'user123' can delete their profile.
     * @deny (create) User with ID 'user456' cannot create a profile with ID 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return isOwner(userId) && resource != null;
      }

      allow get: if isOwner(userId);
      allow list: if false; // User listing is not allowed.
      allow create: if isOwner(userId) && request.auth.uid == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows users to read and write Kanban boards they own.
     * @path /kanbanBoards/{boardId}
     * @allow (create) User with ID 'user123' can create a Kanban board with userId 'user123'.
     * @allow (get) User with ID 'user123' can read a Kanban board with userId 'user123'.
     * @allow (update) User with ID 'user123' can update a Kanban board with userId 'user123'.
     * @allow (delete) User with ID 'user123' can delete a Kanban board with userId 'user123'.
     * @deny (create) User with ID 'user456' cannot create a Kanban board with userId 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /kanbanBoards/{boardId} {
      function isBoardOwner() {
        return request.auth != null && request.auth.uid == resource.data.userId;
      }
      allow get: if isBoardOwner();
      allow list: if false;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if isBoardOwner();
      allow delete: if isBoardOwner();
    }

    /**
     * @description Allows users to read and write Kanban lists within boards they own.
     * @path /kanbanBoards/{boardId}/lists/{listId}
     * @allow (create) User with ID 'user123' can create a Kanban list within their board.
     * @allow (get) User with ID 'user123' can read a Kanban list within their board.
     * @allow (update) User with ID 'user123' can update a Kanban list within their board.
     * @allow (delete) User with ID 'user123' can delete a Kanban list within their board.
     * @deny (create) User with ID 'user456' cannot create a Kanban list within board owned by 'user123'.
     * @principle Enforces document ownership inherited from the parent board.
     */
    match /kanbanBoards/{boardId}/lists/{listId} {
        function isBoardOwner(boardId) {
            return get(/databases/$(database)/documents/kanbanBoards/$(boardId)).data.userId == request.auth.uid;
        }
      allow get: if isBoardOwner(boardId);
      allow list: if false;
      allow create: if isBoardOwner(boardId);
      allow update: if isBoardOwner(boardId);
      allow delete: if isBoardOwner(boardId);
    }

    /**
     * @description Allows users to read and write tasks within boards they own.
     * @path /kanbanBoards/{boardId}/tasks/{taskId}
     * @allow (create) User with ID 'user123' can create a task within their board.
     * @allow (get) User with ID 'user123' can read a task within their board.
     * @allow (update) User with ID 'user123' can update a task within their board.
     * @allow (delete) User with ID 'user123' can delete a task within their board.
     * @deny (create) User with ID 'user456' cannot create a task within board owned by 'user123'.
     * @principle Enforces document ownership inherited from the parent board.
     */
    match /kanbanBoards/{boardId}/tasks/{taskId} {
          function isBoardOwner(boardId) {
            return get(/databases/$(database)/documents/kanbanBoards/$(boardId)).data.userId == request.auth.uid;
        }
      allow get: if isBoardOwner(boardId);
      allow list: if false;
      allow create: if isBoardOwner(boardId);
      allow update: if isBoardOwner(boardId);
      allow delete: if isBoardOwner(boardId);
    }

    /**
     * @description Allows users to read and write their own categories.
     * @path /users/{userId}/categories/{categoryId}
     * @allow (create) User with ID 'user123' can create a category.
     * @allow (get) User with ID 'user123' can read their category.
     * @allow (update) User with ID 'user123' can update their category.
     * @allow (delete) User with ID 'user123' can delete their category.
     * @deny (create) User with ID 'user456' cannot create a category for user 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/categories/{categoryId} {
          function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows users to read and write their own Pomodoro sessions.
     * @path /users/{userId}/pomodoroSessions/{pomodoroSessionId}
     * @allow (create) User with ID 'user123' can create a Pomodoro session.
     * @allow (get) User with ID 'user123' can read their Pomodoro session.
     * @allow (update) User with ID 'user123' can update their Pomodoro session.
     * @allow (delete) User with ID 'user123' can delete their Pomodoro session.
     * @deny (create) User with ID 'user456' cannot create a Pomodoro session for user 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/pomodoroSessions/{pomodoroSessionId} {
          function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows users to read and write their own calendar events.
     * @path /users/{userId}/calendarEvents/{calendarEventId}
     * @allow (create) User with ID 'user123' can create a calendar event.
     * @allow (get) User with ID 'user123' can read their calendar event.
     * @allow (update) User with ID 'user123' can update their calendar event.
     * @allow (delete) User with ID 'user123' can delete their calendar event.
     * @deny (create) User with ID 'user456' cannot create a calendar event for user 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/calendarEvents/{calendarEventId} {
          function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if isOwner(userId);
    }

    /**
     * @description Allows anyone to read cultural events, but only allows server to create, update, delete them.
     * @path /culturalEvents/{culturalEventId}
     * @allow (get) Any user can read cultural events.
     * @deny (create) No client can create cultural events.
     * @deny (update) No client can update cultural events.
     * @deny (delete) No client can delete cultural events.
     * @principle Allows public read access while restricting write access.
     */
    match /culturalEvents/{culturalEventId} {
      allow get: if true;
      allow list: if true;
      allow create: if false; // TODO: Restrict to server-only writes using custom claims or a service account.
      allow update: if false; // TODO: Restrict to server-only writes using custom claims or a service account.
      allow delete: if false; // TODO: Restrict to server-only writes using custom claims or a service account.
    }
  }
}