/**
 * @fileoverview Firestore Security Rules for Axénda application.
 *
 * Core Philosophy:
 * This ruleset employs a strict user-ownership model for most data, ensuring users can only
 * access and modify their own resources. Public read access is granted to some collections
 * like `culturalEvents`, but write access is carefully controlled.
 *
 * Data Structure:
 * - `/users/{userId}`: Stores user profiles, accessible only to the owning user.
 * - `/kanbanBoards/{boardId}`: Stores Kanban boards, accessible to the owning user.
 * - `/kanbanBoards/{boardId}/lists/{listId}`: Stores lists for a specific board, accessible to the owning user.
 * - `/kanbanBoards/{boardId}/tasks/{taskId}`: Stores tasks for a specific board, accessible to the owning user.
 * - `/users/{userId}/categories/{categoryId}`: Stores user-created categories, only accessible to the owning user.
 * - `/users/{userId}/pomodoroSessions/{pomodoroSessionId}`: Stores Pomodoro sessions for a user, only accessible to the owning user.
 * - `/users/{userId}/calendarEvents/{calendarEventId}`: Stores calendar events for a user, only accessible to the owning user.
 * - `/culturalEvents/{culturalEventId}`: Stores global cultural events, publicly readable, but write-protected.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect privacy.
 * - All write operations require authentication.
 * - Data validation is minimized in this prototype to allow for rapid schema iteration.
 *
 * Denormalization for Authorization:
 * The `userId` field is used within documents to denote ownership. This enables direct
 * validation without requiring additional reads. For example, a `Task` document should have
 * a `userId` field that matches the user ID in the `/users/{userId}` path.
 *
 * Structural Segregation:
 * Public data (e.g., `culturalEvents`) and private user data are stored in separate
 * top-level collections to simplify rules and improve performance.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-ownership for user profiles.
     * @path /users/{userId}
     * @allow (create) - User with UID 'user123' can create their profile at /users/user123.
     * @allow (get,update,delete) - User with UID 'user123' can read/update/delete their profile at /users/user123.
     * @deny (create) - User with UID 'user456' cannot create a profile at /users/user123.
     * @deny (update) - User with UID 'user456' cannot update the profile at /users/user123.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if false;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows users to read Kanban boards, but enforces ownership for writes.
     * @path /kanbanBoards/{boardId}
     * @allow (get,list) - Any authenticated user can list or get a KanbanBoard.
     * @allow (create) - User with UID 'user123' can create a KanbanBoard with userId 'user123'.
     * @allow (update,delete) - User with UID 'user123' can update/delete their KanbanBoard.
     * @deny (create) - User with UID 'user456' cannot create a KanbanBoard with userId 'user123'.
     * @deny (update,delete) - User with UID 'user456' cannot update/delete the KanbanBoard owned by 'user123'.
     * @principle Public read, owner-only writes.
     */
    match /kanbanBoards/{boardId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isOwner(boardId) {
        return request.auth != null && request.auth.uid == resource.data.userId;
      }
      function isExistingOwner(boardId) {
        return request.auth != null && request.auth.uid == resource.data.userId;
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update: if isExistingOwner(boardId);
      allow delete: if isExistingOwner(boardId);
    }

    /**
     * @description Enforces user-ownership for Kanban lists within a board.
     * @path /kanbanBoards/{boardId}/lists/{listId}
     * @allow (get,list) - Any authenticated user can get or list KanbanLists.
     * @allow (create) - User with UID 'user123' can create a list within their board.
     * @allow (update,delete) - User with UID 'user123' can update/delete a list within their board.
     * @deny (create) - User with UID 'user456' cannot create a list within board owned by 'user123'.
     * @deny (update,delete) - User with UID 'user456' cannot update/delete a list within board owned by 'user123'.
     * @principle Enforces document ownership for writes.
     */
    match /kanbanBoards/{boardId}/lists/{listId} {
      function isSignedIn() {
        return request.auth != null;
      }
       function isBoardOwner(boardId) {
        return get(/databases/$(database)/documents/kanbanBoards/$(boardId)).data.userId == request.auth.uid;
      }
      function isOwner(boardId) {
        return request.auth != null && isBoardOwner(boardId);
      }
      function isExistingOwner(boardId) {
        return request.auth != null && isBoardOwner(boardId);
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isOwner(boardId);
      allow update: if isExistingOwner(boardId);
      allow delete: if isExistingOwner(boardId);
    }

    /**
     * @description Enforces user-ownership for tasks within a Kanban board.
     * @path /kanbanBoards/{boardId}/tasks/{taskId}
     * @allow (get,list) - Any authenticated user can get or list tasks.
     * @allow (create) - User with UID 'user123' can create a task within their board.
     * @allow (update,delete) - User with UID 'user123' can update/delete a task within their board.
     * @deny (create) - User with UID 'user456' cannot create a task within board owned by 'user123'.
     * @deny (update,delete) - User with UID 'user456' cannot update/delete a task within board owned by 'user123'.
     * @principle Enforces document ownership for writes.
     */
    match /kanbanBoards/{boardId}/tasks/{taskId} {
      function isSignedIn() {
        return request.auth != null;
      }
      function isBoardOwner(boardId) {
        return get(/databases/$(database)/documents/kanbanBoards/$(boardId)).data.userId == request.auth.uid;
      }
       function isOwner(boardId) {
        return request.auth != null && isBoardOwner(boardId);
      }
      function isExistingOwner(boardId) {
        return request.auth != null && isBoardOwner(boardId);
      }

      allow get, list: if isSignedIn();
      allow create: if isSignedIn() && isOwner(boardId);
      allow update: if isExistingOwner(boardId);
      allow delete: if isExistingOwner(boardId);
    }

    /**
     * @description Enforces user-ownership for categories.
     * @path /users/{userId}/categories/{categoryId}
     * @allow (create) - User with UID 'user123' can create a category at /users/user123/categories/cat456.
     * @allow (get,update,delete) - User with UID 'user123' can read/update/delete their category at /users/user123/categories/cat456.
     * @deny (create) - User with UID 'user456' cannot create a category at /users/user123/categories/cat456.
     * @deny (update) - User with UID 'user456' cannot update the category at /users/user123/categories/cat456.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/categories/{categoryId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for Pomodoro sessions.
     * @path /users/{userId}/pomodoroSessions/{pomodoroSessionId}
     * @allow (create) - User with UID 'user123' can create a Pomodoro session at /users/user123/pomodoroSessions/pom123.
     * @allow (get,update,delete) - User with UID 'user123' can read/update/delete their Pomodoro session.
     * @deny (create) - User with UID 'user456' cannot create a Pomodoro session at /users/user123/pomodoroSessions/pom123.
     * @deny (update) - User with UID 'user456' cannot update the Pomodoro session at /users/user123/pomodoroSessions/pom123.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/pomodoroSessions/{pomodoroSessionId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Enforces user-ownership for calendar events.
     * @path /users/{userId}/calendarEvents/{calendarEventId}
     * @allow (create) - User with UID 'user123' can create a calendar event.
     * @allow (get,update,delete) - User with UID 'user123' can read/update/delete their calendar event.
     * @deny (create) - User with UID 'user456' cannot create a calendar event for user 'user123'.
     * @deny (update) - User with UID 'user456' cannot update a calendar event for user 'user123'.
     * @principle Enforces document ownership for all operations.
     */
    match /users/{userId}/calendarEvents/{calendarEventId} {
      function isOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }
      function isExistingOwner(userId) {
        return request.auth != null && request.auth.uid == userId;
      }

      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if isExistingOwner(userId);
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Allows public read access to cultural events, but restricts writes.
     * @path /culturalEvents/{culturalEventId}
     * @allow (get,list) - Any user (authenticated or not) can read cultural events.
     * @deny (create,update,delete) - Only authenticated users can modify cultural events.
     * @principle Public read, owner-only writes (TODO: Implement actual owner check).
     */
    match /culturalEvents/{culturalEventId} {
      function isSignedIn() {
        return request.auth != null;
      }
      allow get, list: if true;
      allow create: if isSignedIn(); // TODO: Add owner validation once the schema is updated with an ownership field.
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }
  }
}