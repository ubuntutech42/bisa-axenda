/**
 * @fileoverview Firestore Security Rules for Axénda application.
 *
 * Core Philosophy:
 * This ruleset enforces a strict user-ownership model for most data.
 * Each user has complete control over their own data (tasks, categories, pomodoro sessions, calendar events)
 * stored under their respective /users/{userId} path.
 * Cultural events are publicly readable.
 *
 * Data Structure:
 * - /users/{userId}: User profile information.
 * - /users/{userId}/tasks/{taskId}: Tasks associated with a user.
 * - /users/{userId}/categories/{categoryId}: Categories created by a user.
 * - /users/{userId}/pomodoroSessions/{pomodoroSessionId}: Pomodoro sessions tracked by a user.
 * - /users/{userId}/calendarEvents/{calendarEventId}: Calendar events created by a user.
 * - /culturalEvents/{culturalEventId}: Global cultural events.
 *
 * Key Security Decisions:
 * - Users can only list tasks, categories, pomodoro sessions, and calendar events that they own.
 * - User listing is implicitly denied (no rule for `/users`).
 * - Cultural events are publicly readable but not writable by users.
 *
 * Denormalization for Authorization:
 * - Each task, category, pomodoro session, and calendar event MUST contain a `userId` field that matches the
 *   `userId` in the path `/users/{userId}`. This is enforced during creation and update to prevent
 *   data inconsistencies and simplify security rules.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Checks if the user is signed in.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     * @param {string} userId - The user ID to compare against.
     * @returns {boolean} - True if the user is the owner, false otherwise.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user is the existing owner of the document.
     * @param {string} userId - The user ID to compare against.
     * @returns {boolean} - True if the user is the owner and the document exists, false otherwise.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Stores user profiles.
     * @path /users/{userId}
     * @allow (create) User with ID 'user123' can create their profile.
     *    Request: { auth: { uid: 'user123' }, resource: { data: { id: 'user123', ... } } }
     * @deny (create) User with ID 'user123' cannot create a profile with a mismatched ID.
     *    Request: { auth: { uid: 'user123' }, resource: { data: { id: 'user456', ... } } }
     * @principle Enforces document ownership for writes, validates relational integrity between documents.
     */
    match /users/{userId} {
      allow get: if false;
      allow list: if false;

      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Stores tasks for a specific user.
     * @path /users/{userId}/tasks/{taskId}
     * @allow (create) User with ID 'user123' can create a task under their user ID.
     *    Request: { auth: { uid: 'user123' }, resource: { data: { userId: 'user123', ... } } }
     * @deny (create) User with ID 'user123' cannot create a task under someone else's user ID.
     *    Request: { auth: { uid: 'user123' }, resource: { data: { userId: 'user456', ... } } }
     * @principle Enforces document ownership for writes, validates relational integrity between documents.
     */
    match /users/{userId}/tasks/{taskId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Stores user-created categories.
     * @path /users/{userId}/categories/{categoryId}
     * @allow (create) User with ID 'user123' can create a category under their user ID.
     *    Request: { auth: { uid: 'user123' }, resource: { data: { userId: 'user123', ... } } }
     * @deny (create) User with ID 'user123' cannot create a category under someone else's user ID.
     *    Request: { auth: { uid: 'user123' }, resource: { data: { userId: 'user456', ... } } }
     * @principle Enforces document ownership for writes, validates relational integrity between documents.
     */
    match /users/{userId}/categories/{categoryId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Stores Pomodoro sessions for a user.
     * @path /users/{userId}/pomodoroSessions/{pomodoroSessionId}
     * @allow (create) User with ID 'user123' can create a Pomodoro session under their user ID.
     *    Request: { auth: { uid: 'user123' }, resource: { data: { userId: 'user123', ... } } }
     * @deny (create) User with ID 'user123' cannot create a Pomodoro session under someone else's user ID.
     *    Request: { auth: { uid: 'user123' }, resource: { data: { userId: 'user456', ... } } }
     * @principle Enforces document ownership for writes, validates relational integrity between documents.
     */
    match /users/{userId}/pomodoroSessions/{pomodoroSessionId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Stores calendar events for a user.
     * @path /users/{userId}/calendarEvents/{calendarEventId}
     * @allow (create) User with ID 'user123' can create a calendar event under their user ID.
     *    Request: { auth: { uid: 'user123' }, resource: { data: { userId: 'user123', ... } } }
     * @deny (create) User with ID 'user123' cannot create a calendar event under someone else's user ID.
     *    Request: { auth: { uid: 'user123' }, resource: { data: { userId: 'user456', ... } } }
     * @principle Enforces document ownership for writes, validates relational integrity between documents.
     */
    match /users/{userId}/calendarEvents/{calendarEventId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);

      allow create: if isOwner(userId) && request.resource.data.userId == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Stores global cultural events.
     * @path /culturalEvents/{culturalEventId}
     * @allow (get) Any user can read cultural events.
     *    Request: { auth: { uid: 'user123' } }
     * @deny (create) No user can create cultural events.
     *    Request: { auth: { uid: 'user123' }, resource: { data: { ... } } }
     * @principle Allows public read access, restricts writes.
     */
    match /culturalEvents/{culturalEventId} {
      allow get: if true;
      allow list: if true;

      allow create: if false;
      allow update: if false;
      allow delete: if false;
    }
  }
}