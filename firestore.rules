
/**
 * @fileoverview Firestore Security Rules for Axénda application.
 *
 * Core Philosophy:
 * This ruleset employs a strict user-ownership model for most data, ensuring users can only
 * access and modify their own resources. Public read access is granted to some collections
 * like `culturalEvents`, but write access is carefully controlled.
 *
 * Data Structure:
 * - `/users/{userId}`: Stores user profiles, accessible only to the owning user.
 * - `/kanbanBoards/{boardId}`: Stores Kanban boards, accessible to users in the 'members' array.
 * - `/kanbanBoards/{boardId}/lists/{listId}`: Stores lists for a specific board.
 * - `/kanbanBoards/{boardId}/tasks/{taskId}`: Stores tasks for a specific board.
 * - `/users/{userId}/categories/{categoryId}`: Stores user-created categories.
 * - `/users/{userId}/pomodoroSessions/{pomodoroSessionId}`: Stores Pomodoro sessions for a user.
 * - `/users/{userId}/calendarEvents/{calendarEventId}`: Stores calendar events for a user.
 * - `/users/{userId}/eventCategories/{eventCategoryId}`: Stores event categories for a user.
 * - `/culturalEvents/{culturalEventId}`: Stores global cultural events, publicly readable.
 *
 * Key Security Decisions:
 * - User listing is disallowed to protect privacy.
 * - All write operations require authentication.
 * - Board access is determined by a 'members' array in the board document.
 * - Data validation is minimized in this prototype for rapid iteration.
 */
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * @description Enforces user-ownership for user profiles.
     * @path /users/{userId}
     */
    match /users/{userId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }
      
      allow read, create, update, delete: if isOwner();
      allow list: if false; // Disallow listing all users for privacy
    }

    /**
     * @description Allows users in the 'members' list to access the board and its contents.
     * The owner is the user with 'userId' property. Only the owner can delete the board or manage members.
     * @path /kanbanBoards/{boardId}
     */
    match /kanbanBoards/{boardId} {
      function isBoardMember() {
        return request.auth != null && get(/databases/$(database)/documents/kanbanBoards/$(boardId)).data.members.hasAny([request.auth.uid]);
      }

      function isBoardOwner() {
          return request.auth != null && resource.data.userId == request.auth.uid;
      }

      function isCreatingOwner() {
        return request.auth != null && request.resource.data.userId == request.auth.uid && request.resource.data.members.hasAny([request.auth.uid]);
      }
      
      allow get: if isBoardMember();
      
      // This rule works with the client-side query `where('members', 'array-contains', user.uid)`.
      // The query itself enforces that users only get boards they are a member of.
      // This rule simply allows such a query to be executed by any authenticated user.
      allow list: if request.auth != null;
      
      allow create: if isCreatingOwner();
      
      // Only the board owner can change the members list or delete the board.
      allow update: if isBoardOwner() && request.resource.data.userId == resource.data.userId;
      
      // Any member can update fields other than 'members' and 'userId'
      allow update: if isBoardMember() 
                    && !('members' in request.resource.data)
                    && !('userId' in request.resource.data);

      allow delete: if isBoardOwner();
    }

    /**
     * @description Enforces that only board members can access lists.
     * @path /kanbanBoards/{boardId}/lists/{listId}
     */
    match /kanbanBoards/{boardId}/lists/{listId} {
      function isBoardMember() {
        return request.auth != null && get(/databases/$(database)/documents/kanbanBoards/$(boardId)).data.members.hasAny([request.auth.uid]);
      }

      allow read, write: if isBoardMember();
    }

    /**
     * @description Enforces that only board members can access tasks.
     * @path /kanbanBoards/{boardId}/tasks/{taskId}
     */
    match /kanbanBoards/{boardId}/tasks/{taskId} {
       function isBoardMember() {
        return request.auth != null && get(/databases/$(database)/documents/kanbanBoards/$(boardId)).data.members.hasAny([request.auth.uid]);
      }

      // Any board member can create/read/update/delete tasks
      allow read, write: if isBoardMember();
    }

    /**
     * @description Enforces user-ownership for categories.
     * @path /users/{userId}/categories/{categoryId}
     */
    match /users/{userId}/categories/{categoryId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      allow read, list, create, update, delete: if isOwner();
    }

    /**
     * @description Enforces user-ownership for Pomodoro sessions.
     * @path /users/{userId}/pomodoroSessions/{pomodoroSessionId}
     */
    match /users/{userId}/pomodoroSessions/{pomodoroSessionId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }

      allow read, list, create, update, delete: if isOwner();
    }
    
    /**
     * @description Enforces user-ownership for event categories.
     * @path /users/{userId}/eventCategories/{eventCategoryId}
     */
    match /users/{userId}/eventCategories/{eventCategoryId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }
      function isCreatingOwner() {
        return request.auth != null && request.auth.uid == userId && request.resource.data.userId == userId;
      }

      allow list, read, update, delete: if isOwner();
      allow create: if isCreatingOwner();
    }

    /**
     * @description Enforces user-ownership for calendar events.
     * @path /users/{userId}/calendarEvents/{calendarEventId}
     */
    match /users/{userId}/calendarEvents/{calendarEventId} {
      function isOwner() {
        return request.auth != null && request.auth.uid == userId;
      }
       function isCreatingOwner() {
        return request.auth != null && request.auth.uid == userId && request.resource.data.userId == userId;
      }

      allow read, list, create, update, delete: if isOwner();
    }

    /**
     * @description Allows public read access to cultural events, but restricts writes.
     * @path /culturalEvents/{culturalEventId}
     */
    match /culturalEvents/{culturalEventId} {
      allow read: if true;
      allow write: if false; // Nobody can write to this collection from the client
    }
  }
}
